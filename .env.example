# ── Restore Platform — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=postgresql://restore:your_password_here@localhost:5432/restore

# Local dev password (matches docker-compose default)
POSTGRES_PASSWORD=restore_dev_secret

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret — use a long random string in production
# Generate: openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_string_in_production

# HMAC secret for audit log chain integrity
# Generate: openssl rand -hex 64
HMAC_SECRET=change_me_to_a_different_long_random_string

# API key for SOAR callback endpoint (machine-to-machine)
AUTOMATION_API_KEY=change_me_automation_api_key

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Provider: openai (default, cheapest) or anthropic
LLM_PROVIDER=openai

# Your API key for the selected provider
LLM_API_KEY=sk-your-openai-or-anthropic-key-here

# Model to use (cost-optimised defaults per provider)
# OpenAI:    gpt-4o-mini  (~$0.15/1M input tokens)
# Anthropic: claude-haiku-4-5-20251001 (cheapest Claude model)
LLM_MODEL=gpt-4o-mini

# ── Storage ───────────────────────────────────────────────────────────────────
# local = store files on disk at ./storage/
# s3    = use S3-compatible object storage (Cloudflare R2, AWS S3, etc.)
STORAGE_PROVIDER=local
STORAGE_BUCKET=restore-evidence

# S3-compatible settings (only needed if STORAGE_PROVIDER=s3)
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_REGION=auto

# ── Email / Notifications ─────────────────────────────────────────────────────
# Leave blank to disable email notifications (in-app only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=restore@yourorg.com

# Optional webhook URL for Silver/Gold notifications (e.g. Teams, Slack)
WEBHOOK_URL=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ── Worker ────────────────────────────────────────────────────────────────────
# How often the background worker polls for new jobs (milliseconds)
WORKER_POLL_INTERVAL_MS=5000

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Consumed by the React app at build time
VITE_API_BASE_URL=http://localhost:3001/api/v1
