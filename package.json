{
  "name": "restore",
  "version": "1.0.0",
  "description": "Restore — Operational Resilience & Recovery Orchestration Platform (Lean MVP)",
  "private": true,
  "workspaces": ["backend", "apps/web"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=apps/web\"",
    "build": "npm run build --workspace=backend && npm run build --workspace=apps/web",
    "db:migrate": "npm run migrate --workspace=backend",
    "db:seed": "npm run seed --workspace=backend",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
